<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cliffcircuit.chat-proxy</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>node</string>
        <string>/Users/openclaw/workspace/cliffcircuit-ai/chat-proxy/server.js</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/openclaw</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/openclaw/workspace/cliffcircuit-ai/chat-proxy</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/chat-proxy.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/chat-proxy-error.log</string>

    <key>UserName</key>
    <string>openclaw</string>
</dict>
</plist>
